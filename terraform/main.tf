          "awslogs-stream-prefix" = "frontend"
        }
      }
    }
  ])

  tags = {
    Name = "${var.project_name}-frontend-task"
  }
}

# ==================== ECS SERVICES ====================
# Ventas API Service
resource "aws_ecs_service" "ventas_api" {
  name            = "${var.project_name}-ventas-api-service"
  cluster         = aws_ecs_cluster.main.id
  task_definition = aws_ecs_task_definition.ventas_api.arn
  desired_count   = var.ecs_desired_count
  launch_type     = "FARGATE"

  network_configuration {
    subnets          = [aws_subnet.private_1.id, aws_subnet.private_2.id]
    security_groups  = [aws_security_group.ecs_tasks.id]
    assign_public_ip = false
  }

  load_balancer {
    target_group_arn = aws_lb_target_group.ventas_api.arn
    container_name   = "ventas-api"
    container_port   = var.container_port
  }

  depends_on = [aws_lb_listener.main]

  tags = {
    Name = "${var.project_name}-ventas-api-service"
  }
}

# Despacho API Service
resource "aws_ecs_service" "despacho_api" {
  name            = "${var.project_name}-despacho-api-service"
  cluster         = aws_ecs_cluster.main.id
  task_definition = aws_ecs_task_definition.despacho_api.arn
  desired_count   = var.ecs_desired_count
  launch_type     = "FARGATE"

  network_configuration {
    subnets          = [aws_subnet.private_1.id, aws_subnet.private_2.id]
    security_groups  = [aws_security_group.ecs_tasks.id]
    assign_public_ip = false
  }

  load_balancer {
    target_group_arn = aws_lb_target_group.despacho_api.arn
    container_name   = "despacho-api"
    container_port   = var.container_port
  }

  depends_on = [aws_lb_listener.main]

  tags = {
    Name = "${var.project_name}-despacho-api-service"
  }
}

# Frontend Service
resource "aws_ecs_service" "frontend" {
  name            = "${var.project_name}-frontend-service"
  cluster         = aws_ecs_cluster.main.id
  task_definition = aws_ecs_task_definition.frontend.arn
  desired_count   = var.ecs_desired_count
  launch_type     = "FARGATE"

  network_configuration {
    subnets          = [aws_subnet.private_1.id, aws_subnet.private_2.id]
    security_groups  = [aws_security_group.ecs_tasks.id]
    assign_public_ip = false
  }

  load_balancer {
    target_group_arn = aws_lb_target_group.frontend.arn
    container_name   = "frontend"
    container_port   = 80
  }

  depends_on = [aws_lb_listener.main]

  tags = {
    Name = "${var.project_name}-frontend-service"
  }
}

# ==================== AUTOSCALING ====================
# Ventas API Auto Scaling
resource "aws_appautoscaling_target" "ventas_api_target" {
  count              = var.enable_autoscaling ? 1 : 0
  max_capacity       = 4
  min_capacity       = var.ecs_desired_count
  resource_id        = "service/${aws_ecs_cluster.main.name}/${aws_ecs_service.ventas_api.name}"
  scalable_dimension = "ecs:service:DesiredCount"
  service_namespace  = "ecs"
}

resource "aws_appautoscaling_policy" "ventas_api_policy" {
  count              = var.enable_autoscaling ? 1 : 0
  policy_name        = "${var.project_name}-ventas-api-scaling"
  policy_type        = "TargetTrackingScaling"
  resource_id        = aws_appautoscaling_target.ventas_api_target[0].resource_id
  scalable_dimension = aws_appautoscaling_target.ventas_api_target[0].scalable_dimension
  service_namespace  = aws_appautoscaling_target.ventas_api_target[0].service_namespace

  target_tracking_scaling_policy_configuration {
    predefined_metric_specification {
      predefined_metric_type = "ECSServiceAverageCPUUtilization"
    }
    target_value = 70.0
  }
}

# Frontend Auto Scaling
resource "aws_appautoscaling_target" "frontend_target" {
  count              = var.enable_autoscaling ? 1 : 0
  max_capacity       = 4
  min_capacity       = var.ecs_desired_count
  resource_id        = "service/${aws_ecs_cluster.main.name}/${aws_ecs_service.frontend.name}"
  scalable_dimension = "ecs:service:DesiredCount"
  service_namespace  = "ecs"
}

resource "aws_appautoscaling_policy" "frontend_policy" {
  count              = var.enable_autoscaling ? 1 : 0
  policy_name        = "${var.project_name}-frontend-scaling"
  policy_type        = "TargetTrackingScaling"
  resource_id        = aws_appautoscaling_target.frontend_target[0].resource_id
  scalable_dimension = aws_appautoscaling_target.frontend_target[0].scalable_dimension
  service_namespace  = aws_appautoscaling_target.frontend_target[0].service_namespace

  target_tracking_scaling_policy_configuration {
    predefined_metric_specification {
      predefined_metric_type = "ECSServiceAverageCPUUtilization"
    }
    target_value = 70.0
  }
}

# ==================== SECRETS MANAGER ====================
resource "aws_secretsmanager_secret" "db_password" {
  name                    = "${var.project_name}-db-password"
  description             = "RDS MySQL database password"
  recovery_window_in_days = 7

  tags = {
    Name = "${var.project_name}-db-password"
  }
}

resource "aws_secretsmanager_secret_version" "db_password" {
  secret_id       = aws_secretsmanager_secret.db_password.id
  secret_string   = var.db_password
}
