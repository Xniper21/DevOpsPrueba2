# ==================== DOCKER COMPOSE ====================
# Registry for images
REGISTRY=docker.io

# Version tag for images
VERSION=1.0.0

# ==================== MYSQL ====================
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=innovatechdb
MYSQL_USER=innovatech
MYSQL_PASSWORD=innovatech123
MYSQL_PORT=3306

# ==================== VITE BUILD ARGS ====================
# Local development
VITE_API_URL_VENTAS=http://localhost/api/ventas
VITE_API_URL_DESPACHOS=http://localhost/api/despachos

# ==================== JAVA OPTIONS ====================
JAVA_OPTS=-XX:+UseG1GC -XX:MaxGCPauseMillis=200 -Xms256m -Xmx512m
